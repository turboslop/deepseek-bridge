{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "containerPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["sqlite", "valkey"]
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "performance": {
      "type": "object",
      "properties": {
        "requestTimeout": {
          "type": "number",
          "minimum": 0.001
        },
        "streamReadTimeout": {
          "type": "number",
          "minimum": 0.001
        },
        "upstreamRetryAttempts": {
          "type": "integer",
          "minimum": 0
        },
        "upstreamRetryInitialDelaySeconds": {
          "type": "number",
          "minimum": 0
        },
        "upstreamRetryMaxDelaySeconds": {
          "type": "number",
          "minimum": 0
        },
        "upstreamRetryJitterSeconds": {
          "type": "number",
          "minimum": 0
        },
        "maxRequestBodyBytes": {
          "type": "integer",
          "minimum": 1
        },
        "maxPoolConnections": {
          "type": "integer",
          "minimum": 1
        },
        "maxThreadPool": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}
